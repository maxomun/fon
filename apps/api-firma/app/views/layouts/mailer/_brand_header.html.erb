<tr>
  <td style="padding:24px 40px;background-color:<%= mail_brand_color(:header) %>;border-bottom:1px solid <%= mail_brand_color(:border) %>;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
      <tr>
        <td align="left" style="vertical-align:middle;">
          <% if mail_logo_visible? %>
            <img
              src="<%= mail_logo_src %>"
              alt="FacturaOn"
              width="200"
              style="display:block;border:0;outline:none;text-decoration:none;max-width:200px;height:auto;"
            >
          <% else %>
            <p style="margin:0;font-family:<%= mail_font_stack %>;font-size:11px;font-weight:600;letter-spacing:0.24em;text-transform:uppercase;color:<%= mail_brand_color(:header_muted) %>;">
              FacturaOn
            </p>
            <p style="margin:6px 0 0;font-family:<%= mail_font_stack %>;font-size:20px;font-weight:600;line-height:1.2;color:<%= mail_brand_color(:primary_text) %>;">
              Arribo
            </p>
          <% end %>
        </td>
      </tr>
    </table>
  </td>
</tr>
