<style>
  @page { size: A4 portrait; margin: 12mm 10mm; }

  * { box-sizing: border-box; }

  body {
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
    color: #222;
    font-size: 12px;
    line-height: 1.35;
  }

  h1, h2, p { margin: 0; }

  /* Encabezado reducido: Chromium lo repite en cada hoja impresa (position: fixed) */
  .encabezado-fijo {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 5px 10mm;
    border-bottom: 1px solid #666;
    background: #fff;
    font-size: 9px;
    line-height: 1.3;
    z-index: 1000;
  }

  .encabezado-fijo strong { font-weight: 700; }

  .documento-cuerpo {
    padding-top: 34px;
  }

  .box {
    border: 1px solid #444;
    padding: 10px;
    margin-bottom: 12px;
  }

  .box-fija {
    page-break-inside: avoid;
    break-inside: avoid;
  }

  .header {
    margin-bottom: 14px;
  }

  .header-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .header-table td {
    border: none;
    padding: 0;
    vertical-align: top;
  }

  .header-logo {
    width: 22%;
    padding-right: 12px;
  }

  .header-logo img {
    display: block;
    max-width: 100%;
    max-height: 72px;
    object-fit: contain;
  }

  .header-emisor {
    width: 48%;
    padding-right: 16px;
  }

  .emisor-nombre,
  .emisor-giro {
    font-weight: 700;
    text-transform: uppercase;
    font-size: 13px;
    line-height: 1.25;
    margin-bottom: 4px;
  }

  .emisor-contacto {
    font-size: 10px;
    line-height: 1.35;
    margin-top: 2px;
    text-transform: uppercase;
  }

  .emisor-correo {
    font-size: 10px;
    color: #1a5490;
    margin-top: 4px;
  }

  .header-dte {
    width: 30%;
    text-align: center;
  }

  .dte-caja {
    border: 2px solid #c40000;
    padding: 10px 8px;
    text-align: center;
  }

  .dte-caja p {
    font-weight: 700;
    font-size: 12px;
    line-height: 1.35;
    margin-bottom: 4px;
  }

  .dte-caja p:last-child {
    margin-bottom: 0;
  }

  .dte-tipo {
    text-transform: uppercase;
    font-size: 11px;
  }

  .dte-folio {
    font-size: 14px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 8px;
  }

  th, td {
    border: 1px solid #999;
    padding: 5px 6px;
    font-size: 11px;
    vertical-align: top;
  }

  th { background: #eee; font-weight: 600; }

  .right { text-align: right; }

  .section-title {
    font-weight: bold;
    margin-bottom: 6px;
    font-size: 12px;
  }

  /* Detalle: permite salto de página entre filas */
  .detalle-box {
    page-break-inside: auto;
    break-inside: auto;
  }

  .detalle-box table {
    page-break-inside: auto;
    break-inside: auto;
  }

  thead { display: table-header-group; }

  tbody tr {
    page-break-inside: avoid;
    break-inside: avoid;
  }

  /* Globales, totales, TED y pie: solo al final (bloque indivisible) */
  .cierre-documento {
    page-break-inside: avoid;
    break-inside: avoid;
  }

  .footer {
    font-size: 10px;
    margin-top: 12px;
    color: #444;
  }

  .ted {
    min-height: 80px;
    border: 1px dashed #666;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8px;
  }

  .ted-barcode {
    display: block;
    min-width: 45mm;
    min-height: 20mm;
    max-width: 90mm;
    max-height: 30mm;
    width: auto;
    height: auto;
    margin: 0 auto;
  }

  .ted-legal {
    font-size: 9px;
    text-align: center;
    margin-top: 6px;
    color: #444;
  }

  .empty-note {
    text-align: center;
    color: #777;
    font-style: italic;
    padding: 8px;
  }
</style>
