<% content_for :preheader do %>
  Confirme su correo para activar su cuenta de persona autorizada en FacturaOn.
<% end %>

<p style="margin:0 0 16px;font-family:<%= mail_font_stack %>;font-size:16px;line-height:1.6;color:<%= mail_brand_color(:text) %>;">
  Hola <strong><%= @nombre %></strong>,
</p>

<p style="margin:0 0 16px;font-family:<%= mail_font_stack %>;font-size:16px;line-height:1.6;color:<%= mail_brand_color(:text) %>;">
  Se creó una cuenta de persona autorizada en <strong>FacturaOn</strong> con este correo.
  Para confirmar que usted controla esta dirección, utilice el siguiente botón:
</p>

<%= render 'layouts/mailer/cta_button', url: @verification_url, label: 'Confirmar mi correo' %>

<%= render 'layouts/mailer/expiry_notice', hours: @expiry_hours %>
