<% content_for :preheader do %>
  Defina su contraseña para completar el acceso a FacturaOn.
<% end %>

<p style="margin:0 0 16px;font-family:<%= mail_font_stack %>;font-size:16px;line-height:1.6;color:<%= mail_brand_color(:text) %>;">
  Hola <strong><%= @nombre %></strong>,
</p>

<p style="margin:0 0 16px;font-family:<%= mail_font_stack %>;font-size:16px;line-height:1.6;color:<%= mail_brand_color(:text) %>;">
  Su correo ya está verificado. Para completar su acceso a <strong>FacturaOn</strong>,
  defina su contraseña con el siguiente botón:
</p>

<%= render 'layouts/mailer/cta_button', url: @password_url, label: 'Establecer mi contraseña' %>

<%= render 'layouts/mailer/expiry_notice', hours: @expiry_hours %>
