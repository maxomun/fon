<% content_for :preheader do %>
  Restablezca su contraseña de acceso a FacturaOn.
<% end %>

<p style="margin:0 0 16px;font-family:<%= mail_font_stack %>;font-size:16px;line-height:1.6;color:<%= mail_brand_color(:text) %>;">
  Hola <strong><%= @nombre %></strong>,
</p>

<p style="margin:0 0 16px;font-family:<%= mail_font_stack %>;font-size:16px;line-height:1.6;color:<%= mail_brand_color(:text) %>;">
  Recibimos una solicitud para restablecer la contraseña de su cuenta en
  <strong>FacturaOn</strong>. Si usted realizó esta solicitud, utilice el siguiente botón:
</p>

<%= render 'layouts/mailer/cta_button', url: @reset_url, label: 'Restablecer mi contraseña' %>

<%= render 'layouts/mailer/expiry_notice', hours: @expiry_hours %>
