# ===========================================
# Variables de entorno para FacturaOn API
# ===========================================
# Copia este archivo a .env y completa los valores
# cp .env.example .env

# ----- Base de Datos -----
DB_HOST=107.20.84.190
DB_PORT=5432
DB_NAME=fon23_dev
DB_USERNAME=user_fon23_dev
DB_PASSWORD=tu_password_aqui

# Base de datos de test (opcional, para pruebas locales)
DB_NAME_TEST=fon23_test

# ----- Rails -----
RAILS_ENV=development
RAILS_MAX_THREADS=5

# ----- JWT -----
# Clave secreta para firmar tokens (genera una con: rails secret)
# Si no se define, usa Rails credentials.secret_key_base
# JWT_SECRET_KEY=tu_clave_secreta_muy_larga_aqui

# ----- CORS -----
# Orígenes permitidos separados por coma
# En desarrollo: * permite todos
# En producción: especificar dominios
CORS_ORIGINS=*

# ----- Opcional: URL completa de BD -----
# Si prefieres usar DATABASE_URL en lugar de variables separadas:
# DATABASE_URL=postgres://user_fon23_dev:password@107.20.84.190:5432/fon23_dev

# ----- Usuarios de personas autorizadas -----
# Password temporal asignado al crear el usuario de una persona autorizada
PERSONA_AUTORIZADA_DEFAULT_PASSWORD=cambiar_en_produccion

# ----- Correo / onboarding -----
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_DOMAIN=gmail.com
SMTP_USERNAME=traroenrolamiento@gmail.com
SMTP_PASSWORD=tu_app_password_de_gmail
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS=true

MAIL_FROM=traroenrolamiento@gmail.com
MAIL_FROM_NAME=FacturaOn Enrolamiento

# URL del frontend para links en correos de onboarding
FRONTEND_BASE_URL=http://localhost:5173

# Horas de validez del token enviado por correo
ONBOARDING_TOKEN_EXPIRY_HOURS=48

# ----- SII (Servicio de Impuestos Internos) -----
# Ambiente: 'certificacion' o 'produccion'
SII_AMBIENTE=certificacion
