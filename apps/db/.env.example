# ===========================================
# PostgreSQL local (Docker) — apps/db
# ===========================================
# cp .env.example .env

# ----- Base de datos local -----
POSTGRES_USER=fon
POSTGRES_PASSWORD=fon_local_dev
POSTGRES_DB=fon23_dev
POSTGRES_PORT=5432

# Base de datos de test (creada en init/01-create-databases.sql)
POSTGRES_DB_TEST=fon23_test

# Respaldo local a restaurar (bootstrap.sh y restore-local.sh)
LOCAL_DUMP_FILE=dumps/respaldo_fon23_dev.sql

# Roles del dump remoto reemplazados por POSTGRES_USER al restaurar
DUMP_REMOTE_ROLES=postgres,user_fon23_dev

# ----- Servidor remoto (solo con --fetch-remote o dump-from-remote.sh) -----
REMOTE_DB_HOST=107.20.84.190
REMOTE_DB_PORT=5432
REMOTE_DB_NAME=fon23_dev
REMOTE_DB_USERNAME=user_fon23_dev
REMOTE_DB_PASSWORD=tu_password_remoto_aqui
